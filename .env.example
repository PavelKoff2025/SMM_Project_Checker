# Flask
FLASK_ENV=development
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key

# Database
DATABASE_URL=sqlite:///smm_checker.db
# DATABASE_URL=postgresql://smm_user:smm_pass@localhost:5432/smm_checker

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# Grok (xAI) API
# Get a key at https://console.x.ai
GROK_API_KEY=
GROK_MODEL=grok-4-1-fast-reasoning

# Uploads
UPLOAD_FOLDER=./uploads

# Queue / rate limiter (optional locally; set in docker-compose)
# REDIS_URL=redis://localhost:6379/0
# RATELIMIT_STORAGE_URI=redis://localhost:6379/1

# Postgres password (docker-compose)
POSTGRES_PASSWORD=smm_pass
